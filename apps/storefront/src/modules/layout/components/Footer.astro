---
interface Props {
  countryCode: string;
}

const { countryCode } = Astro.props;
const currentYear = new Date().getFullYear();

const shopLinks = [
  { href: `/${countryCode}`, label: "Home" },
  { href: `/${countryCode}/store`, label: "All products" },
  { href: `/blog`, label: "Blog" },
  { href: `/${countryCode}/cart`, label: "Cart" },
  { href: `/${countryCode}/checkout`, label: "Checkout" },
];

const companyLinks = [
  { href: `/${countryCode}/about`, label: "About Us" },
  { href: `/${countryCode}/contact`, label: "Contact" },
  { href: `/${countryCode}/delivery-and-payment`, label: "Delivery & Payment" },
  { href: `/${countryCode}/privacy-policy`, label: "Privacy Policy" },
  { href: `/${countryCode}/impressum`, label: "Impressum" },
];
---

<footer class="border-t border-black/10 bg-stone-50">
  <div class="px-8 py-14 md:px-12 lg:px-16">
    <div
      class="grid gap-10 border-b border-black/10 pb-10 md:grid-cols-2 xl:grid-cols-[1.2fr_0.8fr_0.8fr_1fr]"
    >
      <section class="max-w-md">
        <p
          class="text-xl font-serif italic text-stone-750 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-[#9db0ba]"
            viewBox="0 0 100 100"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M50 15 C55 35, 65 45, 85 50 C65 55, 55 65, 50 85 C45 65, 35 55, 15 50 C35 45, 45 35, 50 15 Z" />
            <circle cx="50" cy="50" r="8" class="text-stone-50" fill="currentColor" />
            <circle cx="50" cy="50" r="3" class="text-[#9db0ba]" fill="currentColor" />
            <circle cx="50" cy="28" r="2.5" />
            <circle cx="50" cy="72" r="2.5" />
            <circle cx="28" cy="50" r="2.5" />
            <circle cx="72" cy="50" r="2.5" />
          </svg>
          <span>Ayni Râpé</span>
        </p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-stone-900">
          Sacred Amazonian Shamanic Supplies
        </h2>
        <p class="mt-4 text-sm leading-6 text-stone-600">
          Ethically sourced rapé, tepi & kuripe applicators, aromatics, and ornaments, prepared in strict respect of traditional indigenous practices.
        </p>
      </section>

      <nav aria-label="Footer shop navigation">
        <p class="text-sm font-semibold text-black">Shop</p>
        <ul class="mt-4 space-y-3 text-sm text-black/65">
          {
            shopLinks.map((link) => (
              <li>
                <a class="transition hover:text-black" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Footer company navigation">
        <p class="text-sm font-semibold text-black">Company</p>
        <ul class="mt-4 space-y-3 text-sm text-black/65">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  class="transition hover:text-black"
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <section>
        <p class="text-sm font-semibold text-stone-900">Age Restriction</p>
        <div class="mt-4 space-y-4 text-sm text-stone-600">
          <p class="text-xs border border-amber-200 bg-amber-50/50 p-3 rounded-lg text-amber-800">
            <strong>Warning:</strong> To shop at AyniRape, you must be at least 18 years old. All products are supplied for ethnographic, scientific, and incense/ritual burning purposes.
          </p>
          <a
            class="inline-flex rounded-full bg-[#bdcd00] px-5 py-3 text-xs font-bold text-stone-950 uppercase tracking-wider transition hover:bg-[#a6b400] shadow-sm"
            href={`/${countryCode}/store`}
          >
            Start shopping
          </a>
        </div>
      </section>
    </div>

    <p class="text-sm text-stone-500 pt-6">
      &copy; {currentYear} Ayni Râpé. All rights reserved.
    </p>
  </div>
</footer>
