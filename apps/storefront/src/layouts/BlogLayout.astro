---
import "@styles/global.css";
import { getRegion } from "@lib/data/regions";
import Footer from "@modules/layout/components/Footer.astro";
import { Nav } from "@modules/layout/components/Nav";
import { CartSidebar } from "@modules/layout/components/CartSidebar";
import { ClientRouter } from "astro:transitions";

interface Alternate {
  lang: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  lang?: string;
  type?: "website" | "article";
  publishedTime?: string;
  alternates?: Alternate[];
  jsonLd?: Record<string, unknown>;
}

const SITE_NAME = "AyniRape";
const DEFAULT_REGION = import.meta.env.DEFAULT_REGION ?? "de";

const {
  title,
  description,
  canonicalPath,
  image,
  lang = "en",
  type = "website",
  publishedTime,
  alternates = [],
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, site);
const ogImage = image ? new URL(image, site).href : undefined;
const pageTitle = `${title} | ${SITE_NAME}`;

const region = await getRegion(DEFAULT_REGION);
const regionId = region?.id || null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl.href} />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={new URL(a.href, site).href} />
    ))}

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />

    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} blog`} href="/rss.xml" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="min-h-screen bg-white text-black">
    <div class="mx-auto flex min-h-screen w-full max-w-[1440px] px-4 md:px-8 flex-col">
      <Nav client:load countryCode={DEFAULT_REGION} regionId={regionId} />
      <main class="flex-1 min-h-[calc(100vh-72px)] py-8">
        <slot />
      </main>
      <Footer countryCode={DEFAULT_REGION} />
      <CartSidebar client:load countryCode={DEFAULT_REGION} />
    </div>
  </body>
</html>
