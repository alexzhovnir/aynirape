---
export const prerender = true;

import { getCollection, render } from "astro:content";
import BlogLayout from "@layouts/BlogLayout.astro";
import { getRegion } from "../../lib/data/regions";
import { listProducts } from "../../lib/data/products";

const slugOf = (id: string) => id.replace(/\/index$/, "");

// hreflang path per language variant of the same article.
const localizedPath = (lang: string, slug: string) =>
  lang === "en" ? `/blog/${slug}` : `/${lang}/blog/${slug}`;

export async function getStaticPaths() {
  // getStaticPaths is hoisted and cannot see component-scope consts — define locally.
  const toSlug = (id: string) => id.replace(/\/index$/, "");
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts
    .filter((p) => p.data.language === "en")
    .map((post) => ({ params: { slug: toSlug(post.id) }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth === 2);

// hreflang: siblings that share the same translationKey.
const alternates = post.data.translationKey
  ? (await getCollection("blog", ({ data }) => !data.draft))
      .filter((p) => p.data.translationKey === post.data.translationKey)
      .map((p) => ({ lang: p.data.language, href: localizedPath(p.data.language, slugOf(p.id)) }))
  : [{ lang: "en", href: `/blog/${slugOf(post.id)}` }];

const site = Astro.site ?? new URL(Astro.url.origin);
const url = new URL(`/blog/${slugOf(post.id)}`, site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.publishedDate.toISOString(),
  image: post.data.coverImage ? new URL(post.data.coverImage, site).href : undefined,
  mainEntityOfPage: url,
  publisher: { "@type": "Organization", name: "AyniRape" },
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "2-digit", month: "long", year: "numeric" });

const DEFAULT_REGION = import.meta.env.DEFAULT_REGION ?? "de";
const region = await getRegion(DEFAULT_REGION);
let featuredProducts: any[] = [];
if (region) {
  try {
    const productsList = await listProducts(region.id);
    featuredProducts = productsList.filter((p) => ['nukini-sansara', 'agua-de-florida'].includes(p.handle)).slice(0, 2);
    if (featuredProducts.length === 0) {
      featuredProducts = productsList.slice(0, 2);
    }
  } catch (e) {
    console.error(e);
  }
}
---

<BlogLayout
  title={post.data.title}
  description={post.data.excerpt}
  canonicalPath={`/blog/${slugOf(post.id)}`}
  image={post.data.coverImage}
  lang={post.data.language}
  type="article"
  publishedTime={post.data.publishedDate.toISOString()}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <a href="/blog" class="text-sm text-neutral-500 no-underline hover:underline block mb-6">&larr; Journal</a>
  
  <div class="w-full aspect-[21/9] overflow-hidden rounded-xl bg-stone-100 relative border border-stone-200/40 mb-10">
    <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center select-none bg-stone-100 z-0">
      <span class="font-serif italic text-2xl text-stone-500 mb-1">Ayni Râpé</span>
      <span class="text-xs uppercase tracking-[0.2em] text-stone-400 font-semibold">Journal</span>
    </div>
    {post.data.coverImage && (
      <img
        src={post.data.coverImage}
        alt={post.data.title}
        class="absolute inset-0 w-full h-full object-cover z-10"
        onerror="this.style.opacity='0'; this.style.pointerEvents='none';"
      />
    )}
  </div>

  <div class="grid gap-12 lg:grid-cols-[240px_1fr] xl:grid-cols-[240px_1fr_260px] items-start w-full">
    <!-- Left Sidebar: TOC -->
    <aside class="self-start sticky top-28 hidden lg:block space-y-8">
      {toc.length > 0 && (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-stone-950 mb-4">In this article</h3>
          <ul class="space-y-3">
            {toc.map((h) => (
              <li>
                <a href={`#${h.slug}`} class="text-stone-600 hover:text-[#7a5c00] text-sm font-medium transition-colors block leading-snug">
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Shamanic Promo Card -->
      <div class="bg-stone-50 border border-stone-200/50 p-6 rounded-3xl text-center space-y-4">
        <span class="text-2xl">🌱</span>
        <h4 class="font-bold text-stone-900 text-sm">Authentic Supplies</h4>
        <p class="text-xs text-stone-500 leading-relaxed">Ready for ceremony? Explore our ethically sourced mixtures and tools.</p>
        <a href={`/de/store`} class="inline-block w-full py-2 bg-[#bdcd00] hover:bg-[#a6b400] text-stone-950 text-xs font-bold rounded-full transition-colors cursor-pointer text-center">
          Shop Now
        </a>
      </div>
    </aside>

    <!-- Main article container -->
    <article class="prose prose-neutral max-w-none">
      <h1 class="mt-0">{post.data.title}</h1>
      <div class="flex items-center gap-2 text-xs uppercase tracking-wide text-neutral-500 mb-8 mt-2">
        <span>{fmtDate(post.data.publishedDate)}</span>
        <span>&bull;</span>
        <span class="text-[#7a5c00] font-medium">{post.data.category}</span>
        <span>&bull;</span>
        <span>By {post.data.author}</span>
      </div>
      
      <Content />
    </article>

    <!-- Right Sidebar: Share and Cross-sell -->
    <aside class="self-start sticky top-28 hidden xl:block space-y-10">
      <!-- Social Share -->
      <div class="border-b border-stone-200/60 pb-8">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-stone-950 mb-4">Share</h3>
        <div class="flex flex-col gap-3">
          <a href={`https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-stone-600 hover:text-[#7a5c00] text-sm font-medium transition-colors">
            <svg class="w-4.5 h-4.5 text-stone-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.37.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .24z"/></svg>
            Telegram
          </a>
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title + ' - ' + url)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-stone-600 hover:text-[#7a5c00] text-sm font-medium transition-colors">
            <svg class="w-4.5 h-4.5 text-stone-500" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.864.002-2.637-1.03-5.118-2.91-6.999-1.88-1.882-4.36-2.914-6.999-2.915-5.44 0-9.866 4.424-9.87 9.87-.001 1.778.475 3.51 1.378 5.028l-.987 3.606 3.698-.97z"/></svg>
            WhatsApp
          </a>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(url)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-stone-600 hover:text-[#7a5c00] text-sm font-medium transition-colors">
            <svg class="w-4.5 h-4.5 text-stone-500" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter / X
          </a>
          <button id="copy-link-btn" class="flex items-center gap-2.5 text-stone-600 hover:text-[#7a5c00] text-sm font-medium transition-colors cursor-pointer text-left w-full" data-url={url}>
            <svg class="w-4.5 h-4.5 text-stone-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            <span>Copy Link</span>
          </button>
        </div>
      </div>

      <!-- Featured Products / Cross-sell -->
      {featuredProducts.length > 0 && (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-stone-950 mb-4">Featured Products</h3>
          <div class="space-y-4">
            {featuredProducts.map((p) => (
              <a href={`/${DEFAULT_REGION}/store/${p.id}`} class="flex items-center gap-3 group">
                <div class="w-12 h-12 rounded-full overflow-hidden border border-stone-150 bg-stone-50 shrink-0">
                  <img src={p.thumbnail} alt={p.title} class="w-full h-full object-cover" />
                </div>
                <div class="flex-1 min-w-0 text-left">
                  <h4 class="text-xs font-bold text-stone-900 truncate group-hover:text-[#7a5c00] transition-colors leading-tight">{p.title}</h4>
                  <p class="text-[10px] text-stone-500 mt-0.5">View details &rarr;</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const copyBtn = document.getElementById('copy-link-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          const url = copyBtn.getAttribute('data-url');
          if (url) {
            try {
              await navigator.clipboard.writeText(url);
              const label = copyBtn.querySelector('span');
              if (label) {
                const originalText = label.textContent;
                label.textContent = 'Copied!';
                setTimeout(() => {
                  label.textContent = originalText;
                }, 2000);
              }
            } catch (err) {
              console.error('Failed to copy text: ', err);
            }
          }
        });
      }
    });
  </script>
</BlogLayout>
