---
import Layout from "@layouts/Layout.astro";
import { getRegionParams } from "@lib/params/region-params";

export const getStaticPaths = getRegionParams;

const { countryCode } = Astro.params;
---

<Layout
  title="Contact Us"
  description="Get in touch with Ayni Rapé. Contact us via email or Instagram for inquiries, advice, or custom order requests."
>
  <section class="mx-auto max-w-3xl px-8 py-12 md:px-12 lg:px-16">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-amber-600">
      CONNECT
    </p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-stone-900">
      Contact Ayni Râpé
    </h1>
    <div class="mt-8 space-y-6 text-base leading-8 text-stone-700">
      <p>
        If you have questions about the products, traditional practices, or are interested in meeting us, feel free to get in touch.
      </p>
      
      <div class="bg-stone-50 p-6 rounded-2xl border border-stone-200/50 space-y-4 my-8">
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-stone-500">Email</span>
          <a href="mailto:info@aynirape.com" class="text-amber-600 font-medium hover:underline">info@aynirape.com</a>
        </div>
        <div>
          <span class="block text-xs font-semibold uppercase tracking-wider text-stone-500">Instagram</span>
          <a href="https://www.instagram.com/ayni_rapeh" target="_blank" rel="noreferrer" class="text-amber-600 font-medium hover:underline">@ayni_rapeh</a>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-stone-900 pt-4">Custom Orders & Ceremonies</h2>
      <p>
        We honor traditional craftsmanship. If you would like to have uniquely designed Tepi or Kuripe tubes created especially for you, we can make them to order. Additionally, we offer our expertise as well as initiation ceremonies across Europe upon request. Please contact us via email or Instagram to discuss.
      </p>
      
      <!-- Contact Form -->
      <div class="max-w-md mx-auto pt-10 border-t border-stone-200/60 mt-12">
        <h2 class="text-2xl font-bold text-center text-stone-900 mb-8">Ask a question</h2>
        
        <form id="contact-form" class="space-y-4" data-backend-url={import.meta.env.PUBLIC_MEDUSA_BACKEND_URL}>
          <div>
            <input
              type="text"
              name="name"
              required
              placeholder="Your name"
              class="w-full px-4 py-3 border-b border-stone-200 focus:border-amber-500 focus:outline-none text-stone-900 transition-colors bg-transparent placeholder-stone-400"
            />
          </div>
          <div>
            <input
              type="email"
              name="email"
              required
              placeholder="Your e-mail"
              class="w-full px-4 py-3 border-b border-stone-200 focus:border-amber-500 focus:outline-none text-stone-900 transition-colors bg-transparent placeholder-stone-400"
            />
          </div>
          <div>
            <textarea
              name="message"
              required
              rows="4"
              placeholder="Your message"
              class="w-full px-4 py-3 border-b border-stone-200 focus:border-amber-500 focus:outline-none text-stone-900 transition-colors bg-transparent placeholder-stone-400 resize-none"
            ></textarea>
          </div>
          
          <button
            type="submit"
            class="w-full py-4 px-6 bg-amber-500 text-stone-950 font-bold rounded-full hover:bg-amber-400 transition-colors mt-6 shadow-md cursor-pointer text-center"
          >
            Send
          </button>
          
          <p class="text-[10px] text-stone-400 text-center mt-4 leading-normal">
            By clicking "Send" you accept the <a href={`/${countryCode}/terms`} class="underline">User Agreement</a> and <a href={`/${countryCode}/privacy`} class="underline">consent to the processing of your data</a>.
          </p>
        </form>
        
        <div id="contact-success" class="hidden text-center py-8 text-stone-700 bg-stone-50 border border-stone-200/50 rounded-2xl p-6">
          <p class="font-bold text-lg text-emerald-600 mb-2">Message sent successfully!</p>
          <p class="text-sm">Thank you, we will contact you shortly.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form');
    const successDiv = document.getElementById('contact-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        message: formData.get('message'),
      };

      const backendUrl = form.getAttribute('data-backend-url') || 'http://localhost:9009';

      try {
        const response = await fetch(`${backendUrl}/store/contact`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.classList.add('hidden');
          successDiv.classList.remove('hidden');
        } else {
          alert('Failed to send message. Please try again.');
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred. Please try again.');
      }
    });
  });
</script>
