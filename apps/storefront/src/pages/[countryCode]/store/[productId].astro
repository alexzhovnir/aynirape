---
import Layout from "@layouts/Layout.astro";
import { retrieveProduct, listProducts } from "@lib/data/products";
import { getRegion } from "@lib/data/regions";
import { getProductParams } from "@lib/params/product-params";
import { getProductPrice } from "@lib/utils/get-product-price";
import ImageCarouselWrapper from "@modules/products/components/product-details/image-carousel/ImageCarouselWrapper.astro";
import { ProductActions } from "@modules/products/components/product-details/ProductActions";
import ProductAttributes from "@modules/products/components/product-details/ProductAttributes.astro";
import ProductPreview from "@modules/products/components/product-preview/ProductPreview.astro";

export const getStaticPaths = getProductParams;

const { countryCode, productId } = Astro.params;

if (!countryCode || !productId) {
  return Astro.redirect("/not-found");
}

const region = await getRegion(countryCode);

if (!region) {
  return Astro.redirect("/not-found");
}

let product: Awaited<ReturnType<typeof retrieveProduct>> | undefined;
let relatedProducts: Awaited<ReturnType<typeof listProducts>> = [];
let error: Error | undefined;

try {
  product = await retrieveProduct(productId, region.id);
  const allProducts = await listProducts(region.id);
  relatedProducts = allProducts.filter((p) => p.id !== productId).slice(0, 4);
} catch (e) {
  error = e instanceof Error ? e : new Error("Unknown error");
  console.error(error);
}

const {
  title,
  description,
  images,
  thumbnail,
  options,
  variants,
  material,
  origin_country,
  type,
  weight,
  length,
  width,
  height,
  metadata,
} = product ?? {};

const { cheapestPrice } = getProductPrice({
  productVariants: variants ?? [],
});

const schemaData = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": images && images.length > 0 ? images.map((img) => img.url) : (thumbnail ? [thumbnail] : []),
  "description": description,
  "sku": variants?.[0]?.sku || productId,
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": cheapestPrice?.currency_code?.toUpperCase() || "EUR",
    "lowPrice": cheapestPrice?.calculated_amount,
    "highPrice": cheapestPrice?.original_amount || cheapestPrice?.calculated_amount,
    "offerCount": variants?.length || 1,
    "availability": variants?.some((v) => (v.inventory_quantity ?? 1) > 0)
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
    "url": Astro.url.href,
  },
};
---

<Layout
  title={title}
  description={description ?? `Shop ${title} at the best price.`}
  image={images?.[0]?.url}
  type="product"
>
  <!-- SEO JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <div class="px-8 py-6 md:px-12 lg:px-16 max-w-8xl mx-auto">
    {error && <p class="text-red-700 mb-6">{error.message}</p>}
    {
      product && (
        <div>
          <!-- Breadcrumbs -->
          <nav class="flex items-center gap-2 text-xs text-stone-500 mb-8 font-medium">
            <a href={`/${countryCode}`} class="hover:text-stone-900 transition-colors">Home</a>
            <span class="text-stone-300">/</span>
            <a href={`/${countryCode}/store`} class="hover:text-stone-900 transition-colors">Shop</a>
            {
              product.categories?.[0] && (
                <>
                  <span class="text-stone-300">/</span>
                  <a href={`/${countryCode}/store/category/${product.categories[0].handle}`} class="hover:text-stone-900 transition-colors">
                    {product.categories[0].name}
                  </a>
                </>
              )
            }
            <span class="text-stone-300">/</span>
            <span class="text-stone-900 truncate max-w-[200px]">{title}</span>
          </nav>

          <div class="grid grid-cols-1 gap-20 lg:grid-cols-2">
            <ImageCarouselWrapper
              images={images && images.length > 0 ? images : (thumbnail ? [{ url: thumbnail }] : [])}
              alt={title ?? "Product image"}
            />

            <div class="flex flex-col gap-20">
              <div class="flex flex-col gap-4">
                <h1 class="text-4xl font-bold">{title}</h1>
                <div class="text-gray-500 space-y-4">
                  {description?.split("\n\n").map((paragraph) => (
                    <p class="whitespace-pre-line leading-relaxed">{paragraph}</p>
                  ))}
                </div>
                <p class="text-4xl font-bold">{cheapestPrice?.calculated_price}</p>
              </div>

              <ProductActions
                options={options ?? []}
                variants={variants ?? []}
                productId={productId}
                regionId={region.id}
                client:visible
              />

              <ProductAttributes
                material={material}
                origin_country={origin_country}
                type={type}
                weight={weight}
                length={length}
                width={width}
                height={height}
                metadata={metadata}
              />
            </div>
          </div>

          {relatedProducts.length > 0 && (
            <div class="mt-24 border-t border-stone-200/60 pt-16 pb-20">
              <h2 class="text-3xl font-bold text-stone-900 mb-10 text-center md:text-left">
                People also viewed this item
              </h2>
              <ul class="grid grid-cols-2 md:grid-cols-4 gap-x-10 gap-y-16 w-full">
                {relatedProducts.map((p) => (
                  <li>
                    <ProductPreview
                      id={p.id}
                      variants={p.variants ?? []}
                      thumbnailUrl={p.thumbnail ?? undefined}
                      imageUrl={p.images?.[0]?.url}
                      title={p.title}
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )
    }
  </div>
</Layout>
