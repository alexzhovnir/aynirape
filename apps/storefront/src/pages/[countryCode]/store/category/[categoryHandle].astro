---
import Layout from "@layouts/Layout.astro";
import { getRegion } from "@lib/data/regions";
import { listProducts, listCategories } from "@lib/data/products";
import { getCategoryParams } from "@lib/params/category-params";
import ProductPreview from "@modules/products/components/product-preview/ProductPreview.astro";

export const getStaticPaths = getCategoryParams;

const { countryCode, categoryHandle } = Astro.params;

const region = await getRegion(countryCode);

if (!region) {
  return Astro.redirect("/not-found");
}

let products: Awaited<ReturnType<typeof listProducts>> = [];
let categories: Awaited<ReturnType<typeof listCategories>> = [];
let currentCategory: any = null;
let error: Error | undefined;

try {
  categories = await listCategories();
  currentCategory = categories.find((c) => c.handle === categoryHandle);
  
  if (currentCategory) {
    products = await listProducts(region.id, currentCategory.id);
  } else {
    return Astro.redirect(`/${countryCode}/store`);
  }
} catch (e) {
  error = e instanceof Error ? e : new Error("Unknown error");
  console.error(error);
}

function getCategoryIcon(name: string, handle: string) {
  const normName = name.toLowerCase();
  const normHandle = handle.toLowerCase();

  if (normName.includes("tepi") || normName.includes("kuripe") || normHandle.includes("tepi") || normHandle.includes("kuripe")) {
    // Tepi and Kuripe (wind/blow symbol: two diagonal lines/arrows)
    return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M12 3l4 4M12 3L8 7M12 21l4-4M12 21l-4-4" /></svg>`;
  }
  if (normName.includes("rapé") || normName.includes("rape") || normHandle.includes("rape")) {
    // Rapé (botanical leaf)
    return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925-3.546 5.974 5.974 0 0 0-2.133-1A3.75 3.75 0 0 0 4.5 12a3.75 3.75 0 0 0 3.75 3.75h3.75Z" /></svg>`;
  }
  if (normName.includes("aromat") || normHandle.includes("aromat")) {
    // Aromatics (burning fire/spirit)
    return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /></svg>`;
  }
  if (normName.includes("suppl") || normHandle.includes("suppl")) {
    // Supplements (liquid droplet)
    return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`;
  }
  if (normName.includes("ornament") || normName.includes("decor") || normHandle.includes("ornament") || normHandle.includes("decor")) {
    // Ornaments/Decor (sparkle/gem)
    return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499c.174-.29.619-.29.792 0l1.836 3.064c.08.134.195.247.332.327l3.064 1.836c.29.174.29.619 0 .792l-3.064 1.836a.717.717 0 0 1-.332.327l-1.836 3.064c-.174.29-.619.29-.792 0l-1.836-3.064a.717.717 0 0 1-.332-.327L4.568 11.52c-.29-.174-.29-.619 0-.792l3.064-1.836a.717.717 0 0 1 .332-.327L9.8 3.5Z" /></svg>`;
  }
  
  // Default - All products / Grid
  return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" /></svg>`;
}

const pageTitle = currentCategory ? `${currentCategory.name}` : "Category";
---

<Layout
  title={`${pageTitle} - Shamanic Supplies & Tools`}
  description={`Shop high quality, ethically sourced ${pageTitle} products. Find authentic tribal remedies and ceremony accessories at Ayni Rapé.`}
>
  <div class="px-8 py-6 md:px-12 lg:px-16 max-w-8xl mx-auto">
    <h1 class="mb-8 text-4xl font-bold">{pageTitle}</h1>
    {error && <p class="text-red-700 mb-6">{error.message}</p>}

    <div class="flex flex-col md:flex-row gap-10">
      <!-- Sidebar / Category Filter -->
      <aside class="w-full md:w-64 shrink-0">
        <!-- Desktop Sidebar -->
        <div class="hidden md:flex flex-col gap-6 sticky top-24">
          <h2 class="text-sm font-semibold text-stone-400 uppercase tracking-wider">Categories</h2>
          <nav class="flex flex-col gap-1">
            <a
              href={`/${countryCode}/store`}
              class="flex items-center gap-2 text-left px-3 py-2 rounded-lg text-stone-500 hover:text-stone-900 hover:bg-stone-50/80 transition-all duration-200 cursor-pointer font-medium"
            >
              <Fragment set:html={getCategoryIcon("all", "all")} />
              <span>All Products</span>
            </a>
            {
              categories?.map((cat) => {
                const isActive = cat.id === currentCategory?.id;
                return (
                  <a
                    href={`/${countryCode}/store/category/${cat.handle}`}
                    class={`flex items-center gap-2 text-left px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer font-medium ${
                      isActive
                        ? "text-stone-900 bg-stone-100 font-semibold"
                        : "text-stone-500 hover:text-stone-900 hover:bg-stone-50/80"
                    }`}
                  >
                    <Fragment set:html={getCategoryIcon(cat.name, cat.handle)} />
                    <span>{cat.name}</span>
                  </a>
                );
              })
            }
          </nav>
        </div>

        <!-- Mobile Categories Horizontal Scroll -->
        <div class="md:hidden -mx-8 px-8 overflow-x-auto scrollbar-none flex gap-2 pb-4">
          <a
            href={`/${countryCode}/store`}
            class="flex items-center gap-1.5 whitespace-nowrap px-4 py-2 rounded-full text-sm text-stone-500 bg-stone-100/50 hover:bg-stone-100 transition-all duration-200 cursor-pointer font-medium"
          >
            <Fragment set:html={getCategoryIcon("all", "all")} />
            <span>All Products</span>
          </a>
          {
            categories?.map((cat) => {
              const isActive = cat.id === currentCategory?.id;
              return (
                <a
                  href={`/${countryCode}/store/category/${cat.handle}`}
                  class={`flex items-center gap-1.5 whitespace-nowrap px-4 py-2 rounded-full text-sm transition-all duration-200 cursor-pointer font-medium ${
                    isActive
                      ? "text-stone-900 bg-stone-100 font-semibold"
                      : "text-stone-500 bg-stone-100/50 hover:bg-stone-100"
                  }`}
                >
                  <Fragment set:html={getCategoryIcon(cat.name, cat.handle)} />
                  <span>{cat.name}</span>
                </a>
              );
            })
          }
        </div>
      </aside>

      <!-- Products Grid -->
      <div class="flex-1">
        {products.length === 0 && !error && (
          <p class="text-stone-500 py-8">No products found in this category.</p>
        )}
        <ul
          class="grid sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 w-full gap-x-10 gap-y-16"
        >
          {
            products?.map((product, index) => (
              <li
                class="transition-all duration-250 ease-out origin-center"
              >
                <ProductPreview
                  id={product.id}
                  variants={product.variants ?? []}
                  thumbnailUrl={product.thumbnail ?? undefined}
                  imageUrl={product.images?.[0]?.url}
                  title={product.title}
                  priority={index < 4}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</Layout>
