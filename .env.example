# ─── Backend (Medusa) ───────────────────────────────────────────────
DATABASE_URL=postgres://medusa:medusa@localhost:5432/aynirape
REDIS_URL=redis://localhost:6380
JWT_SECRET=change-me
COOKIE_SECRET=change-me
# Comma-separated allowed origins for the Store/Admin APIs
STORE_CORS=http://localhost:4321
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:4321,http://localhost:9000

# Payments — see ADR-0002 (tobacco/high-risk constraint before choosing a provider)
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# File storage (product images)
# S3_FILE_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET=

# ─── Storefront (Astro + Medusa starter) ────────────────────────────
# Canonical storefront env lives in apps/storefront/.env.example (starter schema).
PUBLIC_MEDUSA_BACKEND_URL=http://127.0.0.1:9009
PUBLIC_MEDUSA_PUBLISHABLE_KEY=
DEFAULT_REGION=de              # ISO-2 country code within the EUR region
PUBLIC_STRIPE_KEY=             # leave empty — tobacco/high-risk, see ADR-0002
S3_DOMAIN=
PUBLIC_INPOST_GEOWIDGET_TOKEN=
PUBLIC_INPOST_SANDBOX=
